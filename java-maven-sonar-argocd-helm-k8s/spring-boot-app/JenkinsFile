stage('SonarQube Code Analysis') {
            steps {
                dir("${WORKSPACE}"){
                // Run SonarQube analysis for Python
                script {
                    def scannerHome = tool name: 'scanner-name', type: 'hudson.plugins.sonar.SonarRunnerInstallation'
                    withSonarQubeEnv('sonar') {
                        sh "${scannerHome}/bin/sonar-scanner \
                            -D sonar.projectVersion=1.0-SNAPSHOT \
                            -D sonar.qualityProfile=test \
                            -D sonar.projectBaseDir=. \
                            -D sonar.projectKey=test \
                            -D sonar.sourceEncoding=UTF-8 \
                            -D sonar.language=maven \
                            -D sonar.host.url=http://77.72.3.41:9000
                    }
                }
            }
            }
       }
