pipeline {
    agent any 
    
    stages { 
        stage('SCM Checkout') {
            steps{
           git branch: 'main', url: 'https://github.com/rafikpnoa/Jenkins-Zero-To-Hero.git'
            }
        }
        // run sonarqube test
        stage('Run Sonarqube') {
            environment {
                SONAR_URL = "http://77.72.3.41:9000";
            }
            steps {
               withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
                 sh 'cd java-maven-sonar-argocd-helm-k8s/spring-boot-app && mvn sonar:sonar -Dsonar.login=$SONAR_AUTH_TOKEN -Dsonar.host.url=${SONAR_URL}'
              }
            }
        }
    }
}
